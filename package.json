  "scripts": {
    "build": "npm run build:prod:firefox && npm run build:prod:chrome",
    "build:dev": "npm run build:dev:firefox && npm run build:dev:chrome",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:dev:firefox": "cross-env BROWSER=firefox NODE_ENV=development tsx scripts/builder/build.ts build",
    "build:prod:firefox": "cross-env BROWSER=firefox NODE_ENV=production tsx scripts/builder/build.ts build",
    "build:dev:chrome": "cross-env BROWSER=chrome NODE_ENV=development tsx scripts/builder/build.ts build",
    "build:prod:chrome": "cross-env BROWSER=chrome NODE_ENV=production tsx scripts/builder/build.ts build"
  },
